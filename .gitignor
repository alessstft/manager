```bash
cat > .gitignore << 'EOF'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual Environment
.venv/
venv/
ENV/
env/

# Database
*.sqlite3
*.db
db.sqlite3

# Django
*.log
local_settings.py
media/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Project specific
**/__pycache__/
**/migrations/*.pyc
!**/migrations/__init__.py

# Setup scripts are fine to keep
!setup.sh
!setup.bat
!requirements.txt
EOF